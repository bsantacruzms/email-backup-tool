<Window x:Class="EmailBackup.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Email Backup Tool"
        Height="800" Width="720"
        MinHeight="640" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextBrush}"
        Background="{StaticResource WindowBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Email Backup Tool" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="Back up any mailbox to Outlook .msg files, zipped as {email}_{date}.zip"
                       Foreground="{StaticResource SubtleBrush}" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Scrollable form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-10,0" Padding="0,0,10,0">
            <StackPanel>

                <!-- Account card -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Account" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10" />

                        <TextBlock Text="Email address" Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="EmailBox" />

                        <TextBlock Text="Password / app password" Foreground="{StaticResource SubtleBrush}" Margin="0,10,0,4" />
                        <PasswordBox x:Name="PasswordBox" />
                        <TextBlock Text="Gmail and Microsoft 365 require an app password, not your normal password."
                                   Foreground="{StaticResource SubtleBrush}" FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Server card -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Server" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Protocol" Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,4" />
                                <ComboBox x:Name="ProtocolBox" SelectedIndex="0">
                                    <ComboBoxItem Content="Auto-detect (recommended)" />
                                    <ComboBoxItem Content="IMAP" />
                                    <ComboBoxItem Content="POP3" />
                                </ComboBox>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="DetectButton" Content="Detect settings"
                                    VerticalAlignment="Bottom" Click="DetectButton_Click" Style="{StaticResource BaseButton}" />
                        </Grid>

                        <TextBlock x:Name="DetectedText" Text="No server settings resolved yet."
                                   Foreground="{StaticResource SubtleBrush}" Margin="0,10,0,0" TextWrapping="Wrap" />

                        <Expander Header="Advanced settings" Margin="0,10,0,0" Foreground="{StaticResource SubtleBrush}">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Login name (optional, if different from email)"
                                           Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,4" />
                                <TextBox x:Name="UserBox" />

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Server host" Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,4" />
                                        <TextBox x:Name="HostBox" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Port" Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,4" />
                                        <TextBox x:Name="PortBox" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Security" Foreground="{StaticResource SubtleBrush}" Margin="0,10,0,4" />
                                <ComboBox x:Name="SecurityBox" SelectedIndex="0">
                                    <ComboBoxItem Content="Auto" />
                                    <ComboBoxItem Content="SSL/TLS (implicit)" />
                                    <ComboBoxItem Content="STARTTLS" />
                                    <ComboBoxItem Content="None (unencrypted)" />
                                </ComboBox>
                                <TextBlock Text="Fill these in to override auto-detect. Leave blank to detect automatically."
                                           Foreground="{StaticResource SubtleBrush}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- Output card -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="Output" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10" />

                        <TextBlock Text="Backup folder" Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="OutputBox" Margin="0,0,10,0" />
                            <Button Grid.Column="1" x:Name="BrowseButton" Content="Browse..."
                                    Click="BrowseButton_Click" Style="{StaticResource BaseButton}" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <CheckBox x:Name="ZipCheck" Content="Create .zip file" IsChecked="True" Margin="0,0,20,0" />
                            <CheckBox x:Name="KeepCheck" Content="Keep .msg folder" IsChecked="True" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Actions + progress + log -->
        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                <Button x:Name="TestButton" Content="Test connection" Click="TestButton_Click"
                        Style="{StaticResource BaseButton}" Margin="0,0,10,0" />
                <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click"
                        Style="{StaticResource BaseButton}" Margin="0,0,10,0" IsEnabled="False" />
                <Button x:Name="BackupButton" Content="Start backup" Click="BackupButton_Click"
                        Style="{StaticResource PrimaryButton}" MinWidth="130" />
            </StackPanel>

            <ProgressBar x:Name="Progress" Minimum="0" Maximum="100" Value="0" />
            <TextBlock x:Name="StatusText" Text="Ready." Foreground="{StaticResource SubtleBrush}" Margin="0,6,0,8" />

            <Border Background="{StaticResource InputBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6">
                <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="NoWrap" BorderThickness="0"
                         Background="Transparent" Foreground="{StaticResource SubtleBrush}"
                         FontFamily="Consolas" FontSize="12" Height="120"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
            </Border>
        </StackPanel>
    </Grid>
</Window>
